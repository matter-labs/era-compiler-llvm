target triple = "evm-unknown-unknown"

define i256 @test(i256 %0) {
; CHECK-LABEL: test:
; CHECK:       ; %bb.0:
; CHECK-NEXT:    JUMPDEST
; CHECK-NEXT:    PUSH1 0x1D
; CHECK-NEXT:    BYTE
; CHECK-NEXT:    SWAP1
; CHECK-NEXT:    JUMP
  %2 = lshr i256 %0, 16
  %3 = and i256 %2, 255
  ret i256 %3
}
