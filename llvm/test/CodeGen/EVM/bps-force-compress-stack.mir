# REQUIRES: asserts
# RUN: llc -x mir -run-pass=evm-backward-propagation-stackification --debug-only=evm-stack-solver < %s 2>&1 | FileCheck %s

# This test case is reduced with llvm-reduce.
# Before the change, the test was reporting a fatal error due to no spillable
# registers found. This is because in the unreachable slots there are only
# literals and no registers that can be spilled. If we run into that situation,
# we are trying to do aggressive stack compression by setting ForceCompressStack=true.
# Test that doing that helps in this case, and we can compile the function successfully.

# CHECK: Unreachable slots found: 1, iteration: 1
# CHECK: Spilling 1 registers
# CHECK: Unreachable slots found: 1, iteration: 2
# CHECK: Spilling 1 registers
# CHECK: Unreachable slots found: 1, iteration: 3
# CHECK: Spilling 1 registers
# CHECK: Unreachable slots found: 1, iteration: 4
# CHECK: EVMStackSolver: no spillable registers found, running with ForceCompressStack=true to avoid stack too deep errors.

--- |
  source_filename = "reduced.ll"
  target datalayout = "E-p:256:256-i256:256:256-S256-a:256:256"
  target triple = "evm-unknown-unknown"

  declare void @llvm.evm.log1(ptr addrspace(1) nocapture readonly, i256, i256) #0

  define void @__entry(ptr addrspace(1) %0, i256 %memory_load_result.i.i1151, i256 %addition_result.i.i1152, ptr addrspace(1) %memory_store_pointer.i60.i1171, i256 %addition_result7.i65.i1175, ptr addrspace(1) %memory_store_pointer.i.i66.i1176, ptr addrspace(1) %1, ptr addrspace(1) %2, ptr addrspace(1) %3, ptr addrspace(1) %4, ptr addrspace(1) %5, i256 %memory_load_result.i60.i1282, i256 %addition_result.i61.i1283, ptr addrspace(1) %memory_store_pointer.i6.i.i63.i1285, i256 %addition_result.i.i.i64.i1286, ptr addrspace(1) %memory_store_pointer.i.i.i65.i1287) {
  entry:
    store i256 0, ptr addrspace(1) %0, align 1
    store i256 49959650844873280387919002902667268181777791899894304871101023422279395049472, ptr addrspace(1) null, align 1
    tail call void @llvm.evm.log1(ptr addrspace(1) null, i256 0, i256 29485693714967335757563038618841744472215891622979272243827124658718922284880)
    store i256 47686107815791987171604627934665496455783052089036221919008672078078989565952, ptr addrspace(1) null, align 1
    store i256 0, ptr addrspace(1) %memory_store_pointer.i60.i1171, align 1
    store i256 14531146437460104441109318256391888888506999037430986136292379498541836402688, ptr addrspace(1) null, align 1
    store i256 1100000000000000000, ptr addrspace(1) %memory_store_pointer.i.i66.i1176, align 1
    tail call void @llvm.evm.log1(ptr addrspace(1) null, i256 0, i256 29485693714967335757563038618841744472215891622979272243827124658718922284880)
    tail call void @llvm.evm.log1(ptr addrspace(1) null, i256 0, i256 18119487874052568832008096351603553032066478434443341304347809448725633250691)
    store i256 14531146437460104441084798327738034666773265484996581189354479672586898767872, ptr addrspace(1) %0, align 1
    store i256 2000000000000000000, ptr addrspace(1) null, align 1
    tail call void @llvm.evm.log1(ptr addrspace(1) null, i256 0, i256 0)
    store i256 14531146437460104441109318256391888888506999037430986136292379498541836402688, ptr addrspace(1) null, align 1
    tail call void @llvm.evm.log1(ptr addrspace(1) null, i256 0, i256 18119487874052568832008096351603553032066478434443341304347809448725633250691)
    store i256 49959650844873280387919002902667268181777791899894304871101023422279395049472, ptr addrspace(1) %0, align 1
    store i256 47686107815791987171604627934665496455783052089036221919008672078078989565952, ptr addrspace(1) null, align 1
    tail call void @llvm.evm.log1(ptr addrspace(1) null, i256 0, i256 0)
