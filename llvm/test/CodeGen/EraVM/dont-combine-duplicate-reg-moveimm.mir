# RUN: llc -x mir -run-pass=eravm-combine-addressing-mode -verify-machineinstrs -compile-twice=false < %s | FileCheck %s

--- |

  target datalayout = "E-p:256:256-i256:256:256-S32-a:256:256"
  target triple = "eravm"

  define void @dont_combine_duplicate_reg_moveimm() { ret void }

...
---
# This test ensures that move-immediate folding does not try to rewrite only
# one side of a two-register use when both inputs are the same register.
# CHECK-LABEL: dont_combine_duplicate_reg_moveimm
# CHECK-LABEL: bb.0:
# CHECK:       $r2 = SUBxrr_s i256 1, $r0, 0
# CHECK-NEXT:  dead $r0 = SUBrrr_v $r2, $r2, i256 0, implicit-def $flags
name:            dont_combine_duplicate_reg_moveimm
tracksRegLiveness: true
body:             |
  bb.0:
    $r2 = SUBxrr_s i256 1, $r0, 0
    dead $r0 = SUBrrr_v $r2, $r2, i256 0, implicit-def $flags
    RET 0

...
